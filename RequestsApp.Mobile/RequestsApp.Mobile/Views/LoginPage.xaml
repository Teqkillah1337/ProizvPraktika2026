<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RequestsApp.Mobile.Views.LoginPage"
             Title="Вход в систему">

    <ScrollView>
        <VerticalStackLayout Spacing="20" Padding="30" VerticalOptions="Center">

            <Label Text="Электронная приёмная" 
                   FontSize="28" 
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   Style="{StaticResource TitleLabel}"/>

            <Label Text="Добро пожаловать" 
                   FontSize="16"
                   HorizontalOptions="Center"
                   Margin="0,0,0,20"
                   Style="{StaticResource SubtitleLabel}"/>

            <HorizontalStackLayout HorizontalOptions="Center" Spacing="30">
                <RadioButton x:Name="rbLogin" Content="Вход" IsChecked="True" Style="{StaticResource RadioButtonStyle}"/>
                <RadioButton x:Name="rbRegister" Content="Регистрация" Style="{StaticResource RadioButtonStyle}"/>
            </HorizontalStackLayout>

            <Label Text="Email" Margin="0,10,0,5" Style="{StaticResource FormLabel}"/>
            <Entry x:Name="txtEmail" 
                   Placeholder="example@mail.ru"
                   Style="{StaticResource FormEntry}"/>

            <Label Text="Пароль" Margin="0,10,0,5" Style="{StaticResource FormLabel}"/>
            <Entry x:Name="txtPassword" 
                   IsPassword="True"
                   Placeholder="..."
                   Style="{StaticResource FormEntry}"/>

            <Button x:Name="btnAuth" 
                    Text="Войти"
                    Style="{StaticResource PrimaryButton}"/>

            <Label x:Name="lblStatus" 
                   HorizontalOptions="Center"
                   IsVisible="False"
                   Style="{StaticResource ErrorLabel}"/>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>