<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Цвета темы (адаптируются под светлую/тёмную) -->
    <Color x:Key="PrimaryColor">#27AE60</Color>
    <Color x:Key="DangerColor">#E74C3C</Color>

    <!-- Фоновые цвета -->
    <Color x:Key="BackgroundColor">#FFFFFF</Color>
    <Color x:Key="DarkBackgroundColor">#1E1E1E</Color>
    <Color x:Key="CardBackgroundColor">#F8F9FA</Color>
    <Color x:Key="DarkCardBackgroundColor">#2D2D2D</Color>

    <!-- Цвета текста -->
    <Color x:Key="TextColor">#212529</Color>
    <Color x:Key="DarkTextColor">#E8E8E8</Color>
    <Color x:Key="SecondaryTextColor">#6C757D</Color>
    <Color x:Key="DarkSecondaryTextColor">#A0A0A0</Color>

    <!-- Границы -->
    <Color x:Key="BorderColor">#DEE2E6</Color>
    <Color x:Key="DarkBorderColor">#404040</Color>

    <!-- Глобальные стили -->
    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource BackgroundColor}, Dark={StaticResource DarkBackgroundColor}}"/>
    </Style>

    <!-- Кнопки -->
    <Style x:Key="PrimaryButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource PrimaryColor}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>

    <Style x:Key="DangerButton" TargetType="Button">
        <Setter Property="BackgroundColor" Value="{StaticResource DangerColor}"/>
        <Setter Property="TextColor" Value="White"/>
        <Setter Property="CornerRadius" Value="8"/>
        <Setter Property="FontAttributes" Value="Bold"/>
        <Setter Property="HeightRequest" Value="50"/>
    </Style>

    <!-- Поля ввода -->
    <Style x:Key="FormEntry" TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBackgroundColor}, Dark={StaticResource DarkCardBackgroundColor}}"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource SecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}"/>
    </Style>

    <Style x:Key="FormPicker" TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBackgroundColor}, Dark={StaticResource DarkCardBackgroundColor}}"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
        <Setter Property="TitleColor" Value="{AppThemeBinding Light={StaticResource SecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}"/>
    </Style>

    <Style x:Key="FormEditor" TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{AppThemeBinding Light={StaticResource CardBackgroundColor}, Dark={StaticResource DarkCardBackgroundColor}}"/>
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
        <Setter Property="PlaceholderColor" Value="{AppThemeBinding Light={StaticResource SecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}"/>
    </Style>

    <!-- Карточки -->
    <Style x:Key="CardBorder" TargetType="Border">
        <Setter Property="Stroke" Value="{AppThemeBinding Light={StaticResource BorderColor}, Dark={StaticResource DarkBorderColor}}"/>
        <Setter Property="Background" Value="{AppThemeBinding Light={StaticResource CardBackgroundColor}, Dark={StaticResource DarkCardBackgroundColor}}"/>
        <Setter Property="StrokeThickness" Value="1"/>
        <Setter Property="StrokeShape" Value="RoundRectangle 10,10,10,10"/>
        <Setter Property="Padding" Value="10"/>
    </Style>
    <!-- Тексты -->
    <Style x:Key="TitleLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
        <Setter Property="FontSize" Value="28"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style x:Key="SubtitleLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource SecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}"/>
        <Setter Property="FontSize" Value="16"/>
    </Style>

    <Style x:Key="FormLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
        <Setter Property="FontAttributes" Value="Bold"/>
    </Style>

    <Style x:Key="ErrorLabel" TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource DangerColor}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <Style x:Key="CardTitle" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
    </Style>

    <Style x:Key="CardSubtitle" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource SecondaryTextColor}, Dark={StaticResource DarkSecondaryTextColor}}"/>
    </Style>

    <Style x:Key="CardText" TargetType="Label">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
    </Style>

    <!-- RadioButton -->
    <Style x:Key="RadioButtonStyle" TargetType="RadioButton">
        <Setter Property="TextColor" Value="{AppThemeBinding Light={StaticResource TextColor}, Dark={StaticResource DarkTextColor}}"/>
    </Style>
</ResourceDictionary>