<Window x:Class="RequestsApp.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Электронная приёмная администрации" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="12" CornerRadius="6" Margin="0,0,0,10">
            <Grid>
                <TextBlock Text="Электронная приёмная" FontSize="18" Foreground="White" 
                           VerticalAlignment="Center" HorizontalAlignment="Left"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Border Background="#34495E" CornerRadius="4" Padding="10,5" Margin="0,0,15,0">
                        <TextBlock x:Name="txtStatus" Foreground="#ECF0F1" FontSize="12" Text="Готово"/>
                    </Border>
                    <TextBlock x:Name="txtUserInfo" Foreground="White" VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выход" Width="80" Height="30"
                            Background="#E74C3C" Foreground="White" FontSize="12" 
                            FontWeight="Bold" Cursor="Hand"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Вкладки -->
        <TabControl Grid.Row="1" FontSize="13">
            <!-- Вкладка: Все заявки -->
            <TabItem Header="Все заявки">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnNewRequest" Content="Новая заявка" Width="120" Height="32"
                                Background="#27AE60" Foreground="White" FontSize="12" 
                                FontWeight="Bold" Cursor="Hand"/>
                        <Button x:Name="btnRefresh" Content="Обновить" Width="100" Height="32"
                                Margin="10,0,0,0" Background="#3498DB" Foreground="White" 
                                FontSize="12" FontWeight="Bold" Cursor="Hand"/>
                    </StackPanel>

                    <DataGrid x:Name="dgvRequests" Grid.Row="1" AutoGenerateColumns="False" 
                              IsReadOnly="True" SelectionMode="Single" SelectionUnit="FullRow"
                              AlternatingRowBackground="#F9F9F9" RowHeight="30">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Номер" Binding="{Binding request_number}" Width="120"/>
                            <DataGridTextColumn Header="Заявитель" Binding="{Binding citizen_name}" Width="150"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding citizen_phone}" Width="120"/>
                            <DataGridTextColumn Header="Категория" Binding="{Binding category_name}" Width="120"/>
                            <DataGridTextColumn Header="Описание" Binding="{Binding description}" Width="250"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding status_name}" Width="100"/>
                            <DataGridTextColumn Header="Дата" Binding="{Binding created_date}" Width="120"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>