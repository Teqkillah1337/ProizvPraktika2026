<Window x:Class="RequestsApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="447" Width="628"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="📋 Электронная приёмная" FontSize="22" 
                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,25"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,20">
            <RadioButton x:Name="rbLogin" Content="Вход" IsChecked="True" 
                         FontSize="14" Margin="0,0,30,0"/>
            <RadioButton x:Name="rbRegister" Content="Регистрация" FontSize="14"/>
        </StackPanel>

        <TextBlock Grid.Row="2" Text="Email:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtEmail" Grid.Row="3" Height="32" Margin="0,0,0,15" 
                 FontSize="13" Padding="5"/>

        <TextBlock Grid.Row="4" Text="Пароль:" FontSize="13" Margin="0,0,0,5"/>
        <PasswordBox x:Name="txtPassword" Grid.Row="5" Height="32" Margin="0,0,0,20" 
                     FontSize="13"/>

        <Button x:Name="btnAuth" Grid.Row="6" Content="Войти" Height="40" 
        Background="#4CAF50" Foreground="White" FontSize="14" 
        FontWeight="Bold" Cursor="Hand"
        Click="BtnAuth_Click"/>

        <TextBlock x:Name="txtStatus" Grid.Row="7" Text="" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,15,0,0" FontSize="12"
                   TextWrapping="Wrap"/>
    </Grid>
</Window>