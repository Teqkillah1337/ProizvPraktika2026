<Window x:Class="RequestsApp.NewRequestWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Новая заявка" Height="528" Width="489"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Создание новой заявки" FontSize="18" 
                   FontWeight="Bold" Margin="0,0,0,20"/>

        <TextBlock Grid.Row="1" Text="ФИО заявителя:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtCitizenName" Grid.Row="2" Height="32" Margin="0,0,0,15" FontSize="13"/>

        <TextBlock Grid.Row="3" Text="Телефон:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtPhone" Grid.Row="4" Height="32" Margin="0,0,0,15" FontSize="13"/>

        <TextBlock Grid.Row="5" Text="Категория:" FontSize="13" Margin="0,0,0,5"/>
        <ComboBox x:Name="cmbCategory" Grid.Row="6" Height="32" Margin="0,0,0,15" FontSize="13"/>

        <TextBlock Grid.Row="7" Text="Описание проблемы:" FontSize="13" Margin="0,0,0,5"/>
        <TextBox x:Name="txtDescription" Grid.Row="8" Height="120" TextWrapping="Wrap" 
                 Margin="0,0,0,20" AcceptsReturn="True" FontSize="13"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,10,0,0">
            <Button x:Name="btnSave" Content="Сохранить" Width="110" Height="35" 
                    Margin="0,0,15,0" Background="#27AE60" Foreground="White" 
                    FontSize="13" FontWeight="Bold" Cursor="Hand"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="110" Height="35" 
                    Background="#E74C3C" Foreground="White" FontSize="13" 
                    FontWeight="Bold" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>